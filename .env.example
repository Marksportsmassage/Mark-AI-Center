# Public Firebase web app config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=mark-ai-center.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=mark-ai-center
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=mark-ai-center.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=514309671076
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-side Firebase Admin
# Prefer Application Default Credentials locally:
#   gcloud auth application-default login
# Or set GOOGLE_APPLICATION_CREDENTIALS to a local service account JSON path.
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_PROJECT_ID=mark-ai-center
# Alternative for hosted server runtimes. Keep this out of git if used.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Owner bootstrap only. Do not hard-code these in source files.
MARK_OWNER_UID=
MARK_OWNER_EMAIL=

# Reserved for later phases. Do not fill until integrations are implemented.
OPENAI_API_KEY=
OPENAI_ROUTE_INTENT_MODEL=gpt-4.1-mini
NEXT_PUBLIC_AI_ROUTE_MODE=mock
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_WEBHOOK_MODE=capture_only
NEXT_PUBLIC_LINE_WEBHOOK_MODE=capture_only
LINE_REPLY_ENABLED=false
NEXT_PUBLIC_LINE_REPLY_ENABLED=false
